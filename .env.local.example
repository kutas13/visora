# ============================================
# Visora (Vercel) — ortam değişkenleri
# Tümünü Vercel: Settings > Environment Variables
# ============================================

# Supabase Proje Ayarlari
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SaaS: Sadece sizin kullanacağınız firma kurulum API anahtarı (POST /api/platform/provision-organization)
# Güçlü rastgele bir değer verin; asla repo veya sohbet ile paylaşmayın.
VISORA_PLATFORM_SETUP_SECRET=your-long-random-secret

# Cron Secret (otomatik bildirim icin)
CRON_SECRET=visora-cron-secret

# WhatsApp - SaaS modelinde varsayilan KAPALI. Acmak isterseniz:
# ENABLE_WHATSAPP=true
# WHATSAPP_NOTIFY_NUMBER=...

# Legacy SMTP - SaaS modelinde varsayilan KAPALI. Sirket bazli SMTP
# yapilandirmasi gelene kadar acmayin:
# ENABLE_LEGACY_EMAIL=true
# SMTP_FROM_EMAIL=...
# SMTP_USER=...
# SMTP_HOST=...
# SMTP_PORT=465
# SMTP_SECURE=true
# MUHASEBE_EMAIL=...

# OpenAI API Anahtari (Visora AI yapay zeka asistani icin)
OPENAI_API_KEY=sk-proj-your-key-here

# Üretim kanonik adres (link önizlemesi, e-posta/cron linkleri)
NEXT_PUBLIC_SITE_URL=https://visora.com.tr
