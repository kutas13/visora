{
  "manifest_version": 3,
  "name": "Vize Form Doldur",
  "version": "1.0.0",
  "description": "Çin vize başvuru formlarını otomatik dolduran akıllı asistan",
  
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  
  "host_permissions": [
    "https://consular.mfa.gov.cn/*"
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vize Form Doldur",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  
  "content_scripts": [
    {
      "matches": ["https://consular.mfa.gov.cn/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}